# =============================================================================
# Massage Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill with your actual values
# For production: Set these in Koyeb Dashboard Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------  
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------  
# 1. Create project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string
# 3. Select "URI" format
# 4. Replace [YOUR-PASSWORD] with your actual password
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Alternative direct connection (without connection pooler):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxx.supabase.co:5432/postgres?schema=public"

# -----------------------------------------------------------------------------  
# Redis (Upstash)
# -----------------------------------------------------------------------------  
# 1. Create database at https://upstash.com
# 2. Go to your database → Redis CLI → Connect
# 3. Copy the rediss:// URL
# IMPORTANT: Use rediss:// (with double s) for SSL/TLS connection
REDIS_URL="rediss://default:[YOUR-REDIS-PASSWORD]@[YOUR-HOST].upstash.io:6379"

# -----------------------------------------------------------------------------  
# Telegram Bot
# -----------------------------------------------------------------------------  
# Get from @BotFather: https://t.me/botfather
BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"

# URL of your Telegram Mini App (Vercel deployment)
# Example: https://massage-bot.vercel.app
WEBAPP_URL="https://your-app.vercel.app"

# Webhook URL for Telegram bot (Koyeb deployment)
# Example: https://massage-bot-api-xxx.koyeb.app
# Leave empty for development (uses long polling)
BOT_WEBHOOK_URL="https://your-api.koyeb.app"

# -----------------------------------------------------------------------------  
# JWT Authentication
# -----------------------------------------------------------------------------  
# Generate a secure random string (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# -----------------------------------------------------------------------------  
# Admin User
# -----------------------------------------------------------------------------  
# Your Telegram ID (get from @userinfobot)
ADMIN_TELEGRAM_ID="123456789"

# -----------------------------------------------------------------------------  
# Portmone Payment (Ukraine) - Optional
# -----------------------------------------------------------------------------  
PORTMONE_PAYEE_ID="your-portmone-payee-id"
PORTMONE_LOGIN="your-portmone-login"
PORTMONE_PASSWORD="your-portmone-password"
PORTMONE_GATEWAY_URL="https://www.portmone.com.ua/gateway/"

# -----------------------------------------------------------------------------  
# Google Calendar Integration - Optional
# -----------------------------------------------------------------------------  
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://your-api.koyeb.app/api/master/calendar/callback"

# -----------------------------------------------------------------------------  
# Application Settings
# -----------------------------------------------------------------------------  
PORT=3000
NODE_ENV="production"

# CORS origin - must match your Vercel frontend URL
CORS_ORIGIN="https://your-app.vercel.app"

# =============================================================================
# KOYEB DEPLOYMENT CHECKLIST
# =============================================================================
# Required Environment Variables in Koyeb Dashboard:
# [ ] DATABASE_URL - from Supabase
# [ ] REDIS_URL - from Upstash (with rediss://)
# [ ] BOT_TOKEN - from @BotFather
# [ ] JWT_SECRET - generate random string
# [ ] WEBAPP_URL - your Vercel URL
# [ ] BOT_WEBHOOK_URL - your Koyeb URL (after first deploy)
# [ ] CORS_ORIGIN - same as WEBAPP_URL
# [ ] ADMIN_TELEGRAM_ID - your Telegram ID
# [ ] NODE_ENV=production
# [ ] PORT=3000
# =============================================================================
